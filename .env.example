# Copy this file to `.env.local` and fill in your Supabase project values.
# .env.local is gitignored, so your keys stay out of version control.
# Find these in Supabase → Project Settings → API.
#
# Without these, the app runs in local-only mode (localStorage, no profile sync).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
